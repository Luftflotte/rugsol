b:["$","section",null,{"id":"results","className":"mb-16","children":[["$","h2",null,{"className":"text-xl font-semibold text-text-primary mb-2","children":"Understanding Results"}],["$","p",null,{"className":"text-sm text-text-secondary mb-8","children":"What each section of the scan report tells you."}],["$","div",null,{"className":"space-y-4","children":[["$","div","Score & Grade",{"className":"glass-card p-5 rounded-2xl","children":[["$","h3",null,{"className":"text-sm font-semibold text-text-primary mb-2","children":"Score & Grade"}],["$","p",null,{"className":"text-sm text-text-secondary leading-relaxed","children":"The overall risk score (0-100) summarizes all checks into a single number. Higher is safer. The letter grade (A through F) provides a quick visual indicator. Critical failures like honeypot detection automatically result in an F grade regardless of other factors."}]]}],["$","div","Security Checks",{"className":"glass-card p-5 rounded-2xl","children":[["$","h3",null,{"className":"text-sm font-semibold text-text-primary mb-2","children":"Security Checks"}],["$","p",null,{"className":"text-sm text-text-secondary leading-relaxed","children":"Each check shows a pass (green), warning (yellow), or fail (red) status. Hover over any check for a detailed explanation. Checks include: mint authority, freeze authority, top holder concentration, liquidity depth, honeypot test, token age, metadata mutability, and more."}]]}],["$","div","Holder Distribution",{"className":"glass-card p-5 rounded-2xl","children":[["$","h3",null,{"className":"text-sm font-semibold text-text-primary mb-2","children":"Holder Distribution"}],["$","p",null,{"className":"text-sm text-text-secondary leading-relaxed","children":"The top 10 holders chart shows what percentage of the total supply is held by the largest wallets. High concentration (e.g., one wallet holding 50%+) is a major risk factor. Known program accounts (like Raydium pools) are labeled separately."}]]}],["$","div","Risk Factors",{"className":"glass-card p-5 rounded-2xl","children":[["$","h3",null,{"className":"text-sm font-semibold text-text-primary mb-2","children":"Risk Factors"}],["$","p",null,{"className":"text-sm text-text-secondary leading-relaxed","children":"The penalty list shows exactly which checks failed and how many points were deducted. This helps you understand which specific risks are present. A token might score well overall but still have one concerning factor worth noting."}]]}]]}]]}]
