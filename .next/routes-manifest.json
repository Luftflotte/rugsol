      "routeKeys": {},
      "namedRegex": "^/api/scan(?:/)?$"
    },
    {
      "page": "/api/stats",
      "regex": "^/api/stats(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/stats(?:/)?$"
    },
    {
      "page": "/api/telegram",
      "regex": "^/api/telegram(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/telegram(?:/)?$"
    },
    {
      "page": "/api-docs",
      "regex": "^/api\\-docs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api\\-docs(?:/)?$"
    },
    {
      "page": "/blog",
